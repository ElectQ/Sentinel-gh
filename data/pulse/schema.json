{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sentinel-gh/pulse",
  "title": "Sentinel-gh daily pulse",
  "description": "Daily digest of followees' public GitHub activity, cross-referenced with GitHub trending, plus stars/forks/follows summaries. Contract for downstream consumers; breaking changes bump schema_version.",
  "type": "object",
  "required": [
    "schema_version",
    "date",
    "generated_at",
    "followee_count",
    "events_collected",
    "trending_available",
    "circle_hot",
    "trending_overlap",
    "releases",
    "new_repos",
    "raw_counts",
    "follows",
    "stars",
    "forks"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 2 },
    "date": { "type": "string", "format": "date" },
    "generated_at": { "type": "string", "format": "date-time" },
    "followee_count": { "type": "integer" },
    "events_collected": { "type": "integer" },
    "trending_available": { "type": "boolean" },
    "trending_source_date": {
      "type": ["string", "null"],
      "description": "Archive date the trending set came from; may lag `date` when today's archive is not yet committed"
    },
    "circle_hot": {
      "type": "array",
      "description": "Repos starred by >= 2 followees today, hottest first",
      "items": { "$ref": "#/$defs/starredRepo" }
    },
    "trending_overlap": {
      "type": "array",
      "description": "Repos starred by any followee today that are also on GitHub trending",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/starredRepo" },
          {
            "properties": {
              "languages": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        ]
      }
    },
    "releases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repo", "by"],
        "properties": {
          "repo": { "type": "string" },
          "by": { "type": "string" },
          "tag": { "type": ["string", "null"] },
          "name": { "type": ["string", "null"] },
          "url": { "type": ["string", "null"] },
          "prerelease": { "type": ["boolean", "null"] }
        }
      }
    },
    "new_repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repo", "by", "created_at"],
        "properties": {
          "repo": { "type": "string" },
          "by": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "starred_repos_total": { "type": "integer" },
    "raw_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "follows": {
      "type": "object",
      "required": ["new_count", "unfollow_count", "items", "unfollows", "truncated_users", "incomplete", "degraded"],
      "properties": {
        "new_count": { "type": "integer" },
        "unfollow_count": { "type": "integer" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "by", "target"],
            "properties": {
              "id": { "type": "string" },
              "by": { "type": "string" },
              "target": { "type": "string" },
              "observed_at": { "type": ["string", "null"] }
            }
          }
        },
        "unfollows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "by", "target"],
            "properties": {
              "id": { "type": "string" },
              "by": { "type": "string" },
              "target": { "type": "string" },
              "observed_at": { "type": ["string", "null"] }
            }
          }
        },
        "truncated_users": { "type": "array", "items": { "type": "string" } },
        "incomplete": { "type": "boolean" },
        "degraded": { "type": "boolean" }
      }
    },
    "stars": {
      "type": "object",
      "required": ["total", "items"],
      "properties": {
        "total": { "type": "integer" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["repo", "by", "created_at"],
            "properties": {
              "repo": { "type": "string" },
              "by": { "type": "string" },
              "created_at": { "type": "string" },
              "trending": { "type": "boolean" },
              "trending_front_page": { "type": "boolean" }
            }
          }
        },
        "truncated": { "type": "boolean" }
      }
    },
    "forks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repo", "by", "created_at"],
        "properties": {
          "repo": { "type": "string" },
          "by": { "type": "string" },
          "forkee": { "type": ["string", "null"] },
          "created_at": { "type": "string" }
        }
      }
    },
    "feed_item_count": { "type": "integer" }
  },
  "$defs": {
    "starredRepo": {
      "type": "object",
      "required": ["repo", "count", "starred_by", "trending"],
      "properties": {
        "repo": { "type": "string" },
        "count": { "type": "integer" },
        "starred_by": { "type": "array", "items": { "type": "string" } },
        "trending": { "type": "boolean" },
        "trending_front_page": { "type": "boolean" }
      }
    }
  }
}
